# =====================================================================
# Plantilla de variables de entorno
# Copiar este archivo como ".env" y completar con valores reales.
# El archivo ".env" NUNCA debe subirse al repositorio (ver .gitignore).
# =====================================================================

# --- Seguridad ---
# Clave secreta para sesiones Flask y tokens CSRF. Generar una nueva con:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esta-clave-por-una-generada-aleatoriamente

# Clave que el firmware del ESP32 debe enviar en el header X-API-Key
# al llamar a /api/dato. Dejar vacia para desactivar la validacion
# (no recomendado fuera de pruebas locales).
RFID_API_KEY=cambia-esta-clave-para-el-esp32

# --- Telegram ---
# IMPORTANTE: el token original incluido en el codigo fuente del
# proyecto debe considerarse comprometido. Genera un token NUEVO con
# @BotFather en Telegram y revoca el anterior.
TELEGRAM_TOKEN=coloca-aqui-tu-token-de-bot-de-telegram
TELEGRAM_TIMEOUT=5
TELEGRAM_MAX_REINTENTOS=3
TELEGRAM_ESPERA_REINTENTO=1.5

# --- Reglas de negocio ---
TIEMPO_BLOQUEO=60

# --- Base de datos ---
DATABASE_PATH=database/asistencia.db

# --- Servidor ---
HOST=0.0.0.0
PORT=5000
DEBUG=false
FLASK_ENV=production

# --- Logging ---
LOG_DIR=logs
LOG_FILE=app.log
LOG_LEVEL=INFO
